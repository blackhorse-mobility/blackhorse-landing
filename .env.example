# HubSpot Integration
# Get your Portal ID from https://app.hubspot.com/personalization/portals
# It's typically a numeric ID (e.g., 1234567)
NEXT_PUBLIC_HUBSPOT_PORTAL_ID=YOUR_PORTAL_ID_HERE

# Optional: For form submissions (CRM contact creation)
# HUBSPOT_PRIVATE_APP_TOKEN=YOUR_PRIVATE_APP_TOKEN_HERE
NEXT_PUBLIC_WHATSAPP_SUPPORT=
